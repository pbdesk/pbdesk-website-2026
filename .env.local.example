# Copy this file to .env.local and fill in the values from your Storyblok space.
# Storyblok dashboard → Settings → Access Tokens / Webhooks for tokens & secrets.

# --- Region ---
# eu | us | ca | ap | cn — defaults to eu when unset.
STORYBLOK_REGION=eu

# --- Content Delivery API tokens ---
# Public (published) content. Required for production builds and visitor traffic.
STORYBLOK_ACCESS_TOKEN=
# Draft / preview content. Used inside the visual editor and via /api/draft.
STORYBLOK_PREVIEW_TOKEN=

# --- Visual editor & webhooks ---
# Random string of your choosing. Required by /api/draft to enable preview.
# Storyblok preview URL: https://<host>/api/draft?secret={SECRET}&slug={story.full_slug}
STORYBLOK_PREVIEW_SECRET=
# HMAC secret configured on the Storyblok webhook (Settings → Webhooks).
# Used by /api/revalidate to verify incoming publish events.
STORYBLOK_WEBHOOK_SECRET=

# --- Migration / seed scripts only (NOT used at runtime) ---
# Personal access token from Storyblok account settings. Required by
# scripts/seed-storyblok.ts and scripts/import-resources.ts.
STORYBLOK_MANAGEMENT_TOKEN=
# Numeric space ID. Required by the same scripts.
STORYBLOK_SPACE_ID=
