# Storyblok region: "eu" or "us" (matches your space)
STORYBLOK_REGION=eu

# Public preview token from Storyblok space settings (Access Tokens > Preview)
# Used for read-only published content in production fetches
STORYBLOK_ACCESS_TOKEN=

# Same/separate preview token used when draft mode is enabled
# Can be the same as STORYBLOK_ACCESS_TOKEN if your space has a single preview token
STORYBLOK_PREVIEW_TOKEN=

# Random secret string protecting the /api/draft endpoint
# Generate with: openssl rand -hex 32
STORYBLOK_PREVIEW_SECRET=

# Webhook secret configured in Storyblok webhook settings
# Used to verify HMAC-SHA1 signature of /api/revalidate POST requests
STORYBLOK_WEBHOOK_SECRET=

# --- Used by scripts/seed-storyblok.ts and scripts/import-resources.ts only ---

# Personal Access Token from your Storyblok account (Account Settings > Personal Access Tokens)
# DO NOT commit. Required only when running the seed/import scripts.
STORYBLOK_MANAGEMENT_TOKEN=

# Numeric Storyblok space ID (Settings > General)
STORYBLOK_SPACE_ID=

# --- Bridge / browser-side config (optional, used by visual editor only) ---

# Public-safe duplicates for the Storyblok bridge running in the browser.
# These are only loaded inside the visual editor iframe (draft mode), so the bridge
# can authenticate against the Content Delivery API for live updates.
NEXT_PUBLIC_STORYBLOK_REGION=eu
NEXT_PUBLIC_STORYBLOK_PREVIEW_TOKEN=
